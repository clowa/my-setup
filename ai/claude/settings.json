{
    "mcpServers": {
        "duckduckgo": {
            "type": "stdio",
            "command": "docker",
            "args": [
                "run",
                "-i",
                "--rm",
                "mcp/duckduckgo:latest"
            ]
        },
        "terraform_registry": {
            "type": "stdio",
            "command": "docker",
            "args": [
                "run",
                "-i",
                "--rm",
                "hashicorp/terraform-mcp-server:0.4.0"
            ]
        },
        "microsoft_azure": {
            "type": "stdio",
            "command": "docker",
            "args": [
                "run",
                "-i",
                "--rm",
                "mcr.microsoft.com/azure-sdk/azure-mcp:latest"
            ]
        },
        "microsoft_docs": {
            "type": "sse",
            "url": "https://learn.microsoft.com/api/mcp"
        },
        "datadog": {
            "type": "http",
            "url": "https://mcp.us3.datadoghq.com/api/unstable/mcp-server/mcp?toolsets=all"
        }
    },
    "permissions": {
        "allow": [
            "Bash(git diff*)",
            "Bash(git log*)",
            "Bash(git status*)",
            "Bash(kubectl get*)",
            "Bash(kubectl describe*)",
            "Bash(kubectl logs*)",
            "Bash(* --help)",
            "WebFetch(domain:registry.terraform.io)",
            "WebFetch(domain:1password.com)",
            "WebFetch(domain:1password.com/blog)",
            "WebFetch(domain:developer.1password.com)",
            "WebFetch(domain:1password.community)",
            "WebFetch(domain:www.1password.community)"
        ],
        "deny": [
            "Read(**/*.secret*)"
        ]
    }
}
